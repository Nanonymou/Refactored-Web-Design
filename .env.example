# Supabase Project URL (from your Supabase project settings)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (public, safe in frontend)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Admin password for the Admin Panel login
# NEVER commit the real value — copy this file to .env and fill it in
VITE_ADMIN_PASSWORD=your-secure-admin-password-here
